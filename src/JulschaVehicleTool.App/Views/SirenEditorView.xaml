<UserControl x:Class="JulschaVehicleTool.App.Views.SirenEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:JulschaVehicleTool.App.Controls"
             xmlns:conv="clr-namespace:JulschaVehicleTool.App.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button Content="Load" Command="{Binding LoadFileCommand}" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Save" Command="{Binding SaveFileCommand}" Padding="12,4" Margin="0,0,12,0" />
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="11" />
        </StackPanel>

        <!-- Placeholder when no data loaded -->
        <TextBlock Grid.Row="1" Text="No carcols.meta loaded. Use Load or File > Import."
                   Style="{DynamicResource PlaceholderTextStyle}"
                   Visibility="{Binding IsLoaded, Converter={StaticResource InverseBoolToVis}}"
                   IsHitTestVisible="False" />

        <!-- Editor -->
        <Grid Grid.Row="1" Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Siren Settings List -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SurfaceVariantBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="8">
                        <TextBlock Text="Siren Settings" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,8" />
                        <Button Content="Add Setting" Command="{Binding AddSirenSettingCommand}"
                                HorizontalAlignment="Stretch" Padding="8,4" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding CarCols.SirenSettings}"
                             SelectedItem="{Binding SelectedSiren}"
                             Margin="4" DisplayMemberPath="Name" />
                </DockPanel>
            </Border>

            <!-- Selected Siren Detail -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" DataContext="{Binding SelectedSiren}">

                    <!-- General -->
                    <Expander Header="General" IsExpanded="True" Margin="0,0,0,8">
                        <StackPanel Margin="8,4">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ID" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding Id, UpdateSourceTrigger=LostFocus}" Width="100" HorizontalAlignment="Left" />
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Name" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=LostFocus}" />
                            </Grid>
                            <controls:NumericSliderControl Label="Time Multiplier" Value="{Binding TimeMultiplier}" Min="0" Max="10" Step="0.1" />
                            <controls:NumericSliderControl Label="Light Falloff Max" Value="{Binding LightFalloffMax}" Min="0" Max="100" Step="0.5" />
                            <controls:NumericSliderControl Label="Light Falloff Exponent" Value="{Binding LightFalloffExponent}" Min="0" Max="100" Step="0.5" />
                            <controls:NumericSliderControl Label="Light Inner Cone" Value="{Binding LightInnerConeAngle}" Min="0" Max="90" Step="0.1" />
                            <controls:NumericSliderControl Label="Light Outer Cone" Value="{Binding LightOuterConeAngle}" Min="0" Max="180" Step="0.5" />
                            <controls:NumericSliderControl Label="Light Offset" Value="{Binding LightOffset}" Min="-10" Max="10" Step="0.01" />
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Texture Name" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding TextureName, UpdateSourceTrigger=LostFocus}" />
                            </Grid>
                            <controls:NumericSliderControl Label="Sequencer BPM" Value="{Binding SequencerBpm}" Min="1" Max="600" Step="1" />
                            <CheckBox Content="Use Real Lights" IsChecked="{Binding UseRealLights}" Margin="0,4"
                                      Foreground="{DynamicResource OnSurfaceBrush}" />
                        </StackPanel>
                    </Expander>

                    <!-- Head/Tail Light Sequencers -->
                    <Expander Header="Head/Tail Light Sequencers" Margin="0,0,0,8">
                        <StackPanel Margin="8,4">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Left Headlight Seq" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding LeftHeadLightSequencer, UpdateSourceTrigger=LostFocus}" FontFamily="Consolas" />
                                <TextBox Grid.Column="2" Text="{Binding LeftHeadLightMultiples, UpdateSourceTrigger=LostFocus}" Margin="4,0,0,0"
                                         HorizontalContentAlignment="Right" ToolTip="Multiples" />
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Right Headlight Seq" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding RightHeadLightSequencer, UpdateSourceTrigger=LostFocus}" FontFamily="Consolas" />
                                <TextBox Grid.Column="2" Text="{Binding RightHeadLightMultiples, UpdateSourceTrigger=LostFocus}" Margin="4,0,0,0"
                                         HorizontalContentAlignment="Right" ToolTip="Multiples" />
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Left Taillight Seq" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding LeftTailLightSequencer, UpdateSourceTrigger=LostFocus}" FontFamily="Consolas" />
                                <TextBox Grid.Column="2" Text="{Binding LeftTailLightMultiples, UpdateSourceTrigger=LostFocus}" Margin="4,0,0,0"
                                         HorizontalContentAlignment="Right" ToolTip="Multiples" />
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Right Taillight Seq" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding RightTailLightSequencer, UpdateSourceTrigger=LostFocus}" FontFamily="Consolas" />
                                <TextBox Grid.Column="2" Text="{Binding RightTailLightMultiples, UpdateSourceTrigger=LostFocus}" Margin="4,0,0,0"
                                         HorizontalContentAlignment="Right" ToolTip="Multiples" />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- Siren Lights -->
                    <Expander Header="Siren Lights (max 20)" IsExpanded="True" Margin="0,0,0,8">
                        <StackPanel Margin="8,4">
                            <Button Content="Add Siren Light"
                                    Command="{Binding DataContext.AddSirenLightCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    HorizontalAlignment="Left" Margin="0,0,0,8" Padding="12,4" />

                            <ItemsControl ItemsSource="{Binding Sirens}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,4">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="0,0,8,0">
                                                        <Rectangle.Fill>
                                                            <SolidColorBrush Color="Red" />
                                                        </Rectangle.Fill>
                                                    </Rectangle>
                                                    <TextBlock Text="{Binding Color, StringFormat='Light - {0}'}" />
                                                </StackPanel>
                                            </Expander.Header>
                                            <StackPanel Margin="16,4">
                                                <!-- Light Properties -->
                                                <TextBlock Text="Light Properties" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,4" />
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Color (ARGB hex)" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1" Text="{Binding Color, UpdateSourceTrigger=LostFocus}" Width="120" HorizontalAlignment="Left" FontFamily="Consolas" />
                                                </Grid>
                                                <controls:NumericSliderControl Label="Intensity" Value="{Binding Intensity}" Min="0" Max="10" Step="0.1" />
                                                <controls:NumericSliderControl Label="Light Group" Value="{Binding LightGroup}" Min="0" Max="255" Step="1" />
                                                <controls:NumericSliderControl Label="Scale Factor" Value="{Binding ScaleFactor}" Min="0" Max="10" Step="0.1" />
                                                <WrapPanel Margin="0,4">
                                                    <CheckBox Content="Rotate" IsChecked="{Binding Rotate}" Margin="0,0,12,0" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                    <CheckBox Content="Scale" IsChecked="{Binding Scale}" Margin="0,0,12,0" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                    <CheckBox Content="Flash" IsChecked="{Binding Flash}" Margin="0,0,12,0" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                    <CheckBox Content="Light" IsChecked="{Binding Light}" Margin="0,0,12,0" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                    <CheckBox Content="SpotLight" IsChecked="{Binding SpotLight}" Margin="0,0,12,0" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                    <CheckBox Content="Cast Shadows" IsChecked="{Binding CastShadows}" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                </WrapPanel>

                                                <!-- Rotation -->
                                                <TextBlock Text="Rotation" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,8,0,4" />
                                                <controls:NumericSliderControl Label="Delta" Value="{Binding RotationDelta}" Min="-180" Max="180" Step="0.1" />
                                                <controls:NumericSliderControl Label="Start" Value="{Binding RotationStart}" Min="-180" Max="180" Step="0.1" />
                                                <controls:NumericSliderControl Label="Speed" Value="{Binding RotationSpeed}" Min="0" Max="20" Step="0.1" />
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="80" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Sequencer" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1" Text="{Binding RotationSequencer, UpdateSourceTrigger=LostFocus}" FontFamily="Consolas" />
                                                    <TextBox Grid.Column="2" Text="{Binding RotationMultiples, UpdateSourceTrigger=LostFocus}" Margin="4,0,0,0"
                                                             HorizontalContentAlignment="Right" ToolTip="Multiples" />
                                                </Grid>
                                                <WrapPanel Margin="0,4">
                                                    <CheckBox Content="Direction" IsChecked="{Binding RotationDirection}" Margin="0,0,12,0" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                    <CheckBox Content="Sync to BPM" IsChecked="{Binding RotationSyncToBpm}" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                </WrapPanel>

                                                <!-- Flashiness -->
                                                <TextBlock Text="Flashiness" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,8,0,4" />
                                                <controls:NumericSliderControl Label="Delta" Value="{Binding FlashinessDelta}" Min="-180" Max="180" Step="0.1" />
                                                <controls:NumericSliderControl Label="Start" Value="{Binding FlashinessStart}" Min="-180" Max="180" Step="0.1" />
                                                <controls:NumericSliderControl Label="Speed" Value="{Binding FlashinessSpeed}" Min="0" Max="20" Step="0.1" />
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="80" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Sequencer" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1" Text="{Binding FlashinessSequencer, UpdateSourceTrigger=LostFocus}" FontFamily="Consolas" />
                                                    <TextBox Grid.Column="2" Text="{Binding FlashinessMultiples, UpdateSourceTrigger=LostFocus}" Margin="4,0,0,0"
                                                             HorizontalContentAlignment="Right" ToolTip="Multiples" />
                                                </Grid>
                                                <WrapPanel Margin="0,4">
                                                    <CheckBox Content="Direction" IsChecked="{Binding FlashinessDirection}" Margin="0,0,12,0" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                    <CheckBox Content="Sync to BPM" IsChecked="{Binding FlashinessSyncToBpm}" Foreground="{DynamicResource OnSurfaceBrush}" />
                                                </WrapPanel>

                                                <!-- Corona -->
                                                <TextBlock Text="Corona" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,8,0,4" />
                                                <controls:NumericSliderControl Label="Intensity" Value="{Binding CoronaIntensity}" Min="0" Max="200" Step="1" />
                                                <controls:NumericSliderControl Label="Size" Value="{Binding CoronaSize}" Min="0" Max="10" Step="0.01" />
                                                <controls:NumericSliderControl Label="Pull" Value="{Binding CoronaPull}" Min="0" Max="5" Step="0.01" />
                                                <CheckBox Content="Face Camera" IsChecked="{Binding CoronaFaceCamera}" Margin="0,4"
                                                          Foreground="{DynamicResource OnSurfaceBrush}" />
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
