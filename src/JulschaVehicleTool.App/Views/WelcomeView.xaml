<UserControl x:Class="JulschaVehicleTool.App.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JulschaVehicleTool.App.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance vm:WelcomeViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
        <StackPanel>
            <!-- Logo / Title -->
            <materialDesign:PackIcon Kind="CarSide"
                                     Width="48" Height="48"
                                     Foreground="{DynamicResource AccentBrush}"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,12" />

            <TextBlock Text="Julscha Vehicle Tool"
                       FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />

            <TextBlock Text="FiveM Vehicle Resource Builder"
                       FontSize="13"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,36" />

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,36">
                <Button Command="{Binding NewProjectCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        MinWidth="160" Height="40"
                        Foreground="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderPlus" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="New Project" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenProjectCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        MinWidth="160" Height="40"
                        Foreground="{DynamicResource OnSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Open Project" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Recent Projects -->
            <TextBlock Text="RECENT PROJECTS"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecentProjects.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding RecentProjects}" Margin="0,0,0,36">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="12,10"
                                Margin="0,0,0,2"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding FilePath}" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="FolderOpenOutline"
                                                         Width="20" Height="20"
                                                         Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource OnSurfaceBrush}" />
                                    <TextBlock Text="{Binding FolderPath}"
                                               FontSize="11"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="ItemBorder" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                        Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Branding -->
            <TextBlock Text="&#169; 2026 Julscha"
                       FontSize="11"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
