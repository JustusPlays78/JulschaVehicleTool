<UserControl x:Class="JulschaVehicleTool.App.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JulschaVehicleTool.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:WelcomeViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
        <StackPanel>
            <!-- Title -->
            <TextBlock Text="Julscha Vehicle Tool"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <TextBlock Text="FiveM Vehicle Resource Builder"
                       FontSize="14"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40" />

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                <Button Content="New Project"
                        Command="{Binding NewProjectCommand}"
                        Padding="20,10" FontSize="14"
                        Margin="0,0,12,0" />
                <Button Content="Open Project"
                        Command="{Binding OpenProjectCommand}"
                        Padding="20,10" FontSize="14" />
            </StackPanel>

            <!-- Recent Projects -->
            <TextBlock Text="RECENT PROJECTS"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecentProjects.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding RecentProjects}" Margin="0,0,0,40">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceVariantBrush}"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,0,0,4"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding FilePath}" />
                            </Border.InputBindings>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceBrush}" />
                                <TextBlock Text="{Binding FolderPath}"
                                           FontSize="11"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Branding -->
            <TextBlock Text="&#169; 2026 Julscha"
                       FontSize="11"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
