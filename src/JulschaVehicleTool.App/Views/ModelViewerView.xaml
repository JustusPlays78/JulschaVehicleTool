<UserControl x:Class="JulschaVehicleTool.App.Views.ModelViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
             xmlns:conv="clr-namespace:JulschaVehicleTool.App.Converters">
    <UserControl.Resources>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button Content="Load YFT" Command="{Binding LoadModelCommand}"
                    Padding="12,4" Margin="0,0,12,0" />
            <TextBlock Text="LOD:" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}" />
            <ComboBox ItemsSource="{Binding LodLevels}"
                      SelectedItem="{Binding SelectedLod}"
                      Width="100" />
            <CheckBox Content="Wireframe" IsChecked="{Binding ShowWireframe}"
                      Margin="16,0,0,0" VerticalAlignment="Center"
                      Foreground="{DynamicResource OnSurfaceVariantBrush}" />
            <CheckBox Content="Textures" IsChecked="{Binding ShowTextures}"
                      Margin="16,0,0,0" VerticalAlignment="Center"
                      Foreground="{DynamicResource OnSurfaceVariantBrush}" />
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                       Margin="16,0,0,0" Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="11" />
        </StackPanel>

        <!-- Row 1: 3D Viewport + Texture Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 3D Viewport -->
            <hx:Viewport3DX x:Name="Viewport" Grid.Column="0"
                             Camera="{Binding Camera}"
                             EffectsManager="{Binding EffectsManager}"
                             BackgroundColor="#11111B"
                             ShowCoordinateSystem="True"
                             CoordinateSystemLabelForeground="White"
                             ZoomExtentsWhenLoaded="True"
                             EnableSwapChainRendering="True">

                <!-- Lighting -->
                <hx:AmbientLight3D Color="#404040" />
                <hx:DirectionalLight3D Color="#CCCCCC" Direction="-1,-1,-1" />
                <hx:DirectionalLight3D Color="#666666" Direction="1,0.5,0.5" />

            </hx:Viewport3DX>

            <!-- Overlay when no model loaded -->
            <TextBlock Grid.Column="0"
                       Text="Load a .yft file to view the 3D model"
                       Style="{DynamicResource PlaceholderTextStyle}"
                       Visibility="{Binding IsLoaded, Converter={StaticResource InverseBoolToVis}}"
                       IsHitTestVisible="False" />

            <!-- Texture Panel (visible only when textures are loaded) -->
            <Border Grid.Column="1" Width="160"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Visibility="{Binding HasTextures, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding TexturePanelHeader}"
                               FontSize="11" FontWeight="SemiBold" Margin="8,6"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Textures}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="4" CornerRadius="3"
                                            Background="{DynamicResource HoverBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Thumbnail}" Width="32" Height="32"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding DisplayText}"
                                                       FontSize="10" TextWrapping="Wrap" MaxWidth="108"
                                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
