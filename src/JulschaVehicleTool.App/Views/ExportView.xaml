<UserControl x:Class="JulschaVehicleTool.App.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="700" HorizontalAlignment="Left">
            <TextBlock Text="FiveM Export" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,24" />

            <!-- Resource Info -->
            <Expander Header="Resource Information" IsExpanded="True" Margin="0,0,0,12">
                <StackPanel Margin="8,4">
                    <TextBlock Text="Resource Name" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ResourceName}" Margin="0,0,0,8" />

                    <TextBlock Text="Author" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Author}" Margin="0,0,0,8" />

                    <TextBlock Text="Version" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Version}" Margin="0,0,0,8" />
                </StackPanel>
            </Expander>

            <!-- Vehicles in Project -->
            <Expander Header="Vehicles in Project" IsExpanded="True" Margin="0,0,0,12">
                <StackPanel Margin="8,4">
                    <TextBlock Text="Files are managed via the sidebar (Add Vehicle / Import Files)."
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{Binding Vehicles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceVariantBrush}"
                                        CornerRadius="4" Padding="12,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                                   Margin="0,0,0,4" />
                                        <WrapPanel>
                                            <!-- Stream files -->
                                            <TextBlock Margin="0,0,8,0" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="YFT" />
                                                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding YftFilePath}" Value="{x:Null}">
                                                                <Setter Property="Opacity" Value="0.3" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,8,0" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="YTD" />
                                                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding YtdFilePath}" Value="{x:Null}">
                                                                <Setter Property="Opacity" Value="0.3" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Meta files -->
                                            <TextBlock Margin="0,0,8,0" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Handling" />
                                                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HandlingMetaPath}" Value="{x:Null}">
                                                                <Setter Property="Opacity" Value="0.3" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,8,0" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Vehicles" />
                                                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VehiclesMetaPath}" Value="{x:Null}">
                                                                <Setter Property="Opacity" Value="0.3" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,8,0" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="CarVars" />
                                                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CarVariationsMetaPath}" Value="{x:Null}">
                                                                <Setter Property="Opacity" Value="0.3" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,8,0" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="CarCols" />
                                                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CarColsMetaPath}" Value="{x:Null}">
                                                                <Setter Property="Opacity" Value="0.3" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No vehicles added yet."
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               FontStyle="Italic" FontSize="12" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Vehicles.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Expander>

            <!-- Vehicle Names -->
            <Expander Header="Vehicle Names" Margin="0,0,0,12">
                <StackPanel Margin="8,4">
                    <CheckBox Content="Include vehicle_names.lua (auto-generated from vehicle names)"
                              IsChecked="{Binding IncludeVehicleNames}"
                              Foreground="{DynamicResource OnSurfaceBrush}"
                              Margin="0,0,0,4" />
                    <TextBlock Text="Model names are derived from YFT filenames. Display names use the vehicle name from the sidebar."
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </Expander>

            <!-- Output -->
            <TextBlock Text="Output Folder" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="Browse" Command="{Binding BrowseOutputPathCommand}"
                        Margin="4,0,0,0" Padding="12,4" />
                <TextBox Text="{Binding OutputPath}" />
            </DockPanel>

            <Button Content="Export Resource" Command="{Binding ExportCommand}"
                    HorizontalAlignment="Stretch" Padding="12,8" Margin="0,0,0,12" />

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="12" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
