<UserControl x:Class="JulschaVehicleTool.App.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Content" Value="..." />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="700" HorizontalAlignment="Left">
            <TextBlock Text="FiveM Export" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceBrush}" Margin="0,0,0,24" />

            <!-- Resource Info -->
            <Expander Header="Resource Information" IsExpanded="True" Margin="0,0,0,12">
                <StackPanel Margin="8,4">
                    <TextBlock Text="Resource Name" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ResourceName}" Margin="0,0,0,8" />

                    <TextBlock Text="Author" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Author}" Margin="0,0,0,8" />

                    <TextBlock Text="Version" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Version}" Margin="0,0,0,8" />
                </StackPanel>
            </Expander>

            <!-- Stream Files -->
            <Expander Header="Stream Files" Margin="0,0,0,12">
                <StackPanel Margin="8,4">
                    <TextBlock Text="Vehicle Model (.yft)" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseYftCommand}" />
                        <TextBox Text="{Binding YftPath}" />
                    </DockPanel>

                    <TextBlock Text="High-Detail Model (_hi.yft)" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseYftHiCommand}" />
                        <TextBox Text="{Binding YftHiPath}" />
                    </DockPanel>

                    <TextBlock Text="Textures (.ytd)" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseYtdCommand}" />
                        <TextBox Text="{Binding YtdPath}" />
                    </DockPanel>

                    <TextBlock Text="High-Detail Textures (+hi.ytd)" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseYtdHiCommand}" />
                        <TextBox Text="{Binding YtdHiPath}" />
                    </DockPanel>
                </StackPanel>
            </Expander>

            <!-- Meta Files -->
            <Expander Header="Meta Files" Margin="0,0,0,12">
                <StackPanel Margin="8,4">
                    <TextBlock Text="handling.meta" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseHandlingMetaCommand}" />
                        <TextBox Text="{Binding HandlingMetaPath}" />
                    </DockPanel>

                    <TextBlock Text="vehicles.meta" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseVehiclesMetaCommand}" />
                        <TextBox Text="{Binding VehiclesMetaPath}" />
                    </DockPanel>

                    <TextBlock Text="carvariations.meta" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseCarVariationsMetaCommand}" />
                        <TextBox Text="{Binding CarVariationsMetaPath}" />
                    </DockPanel>

                    <TextBlock Text="carcols.meta" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseCarColsMetaCommand}" />
                        <TextBox Text="{Binding CarColsMetaPath}" />
                    </DockPanel>

                    <TextBlock Text="vehiclelayouts.meta" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseBtn}" Command="{Binding BrowseVehicleLayoutsMetaCommand}" />
                        <TextBox Text="{Binding VehicleLayoutsMetaPath}" />
                    </DockPanel>
                </StackPanel>
            </Expander>

            <!-- Vehicle Names -->
            <Expander Header="Vehicle Names" Margin="0,0,0,12">
                <StackPanel Margin="8,4">
                    <CheckBox Content="Include vehicle_names.lua"
                              IsChecked="{Binding IncludeVehicleNames}"
                              Foreground="{DynamicResource OnSurfaceBrush}"
                              Margin="0,0,0,8" />

                    <TextBlock Text="Model Name (spawn name)" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding VehicleModelName}" Margin="0,0,0,8" />

                    <TextBlock Text="Display Name" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding VehicleDisplayName}" Margin="0,0,0,8" />
                </StackPanel>
            </Expander>

            <!-- Output -->
            <TextBlock Text="Output Folder" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,0,0,4" />
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right" Content="Browse" Command="{Binding BrowseOutputPathCommand}"
                        Margin="4,0,0,0" Padding="12,4" />
                <TextBox Text="{Binding OutputPath}" />
            </DockPanel>

            <Button Content="Export Resource" Command="{Binding ExportCommand}"
                    HorizontalAlignment="Stretch" Padding="12,8" Margin="0,0,0,12" />

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="12" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
