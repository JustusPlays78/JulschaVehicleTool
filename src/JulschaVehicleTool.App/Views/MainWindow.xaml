<Window x:Class="JulschaVehicleTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:JulschaVehicleTool.App.ViewModels"
        xmlns:views="clr-namespace:JulschaVehicleTool.App.Views"
        Title="{Binding TitleSuffix, StringFormat='Julscha Vehicle Tool{0}'}"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <!-- DataTemplates for View switching -->
        <DataTemplate DataType="{x:Type vm:ModelViewerViewModel}">
            <views:ModelViewerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HandlingEditorViewModel}">
            <views:HandlingEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarVariationsViewModel}">
            <views:CarVariationsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SirenEditorViewModel}">
            <views:SirenEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VehicleMetaViewModel}">
            <views:VehicleMetaView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExportViewModel}">
            <views:ExportView />
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}" />
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenProjectCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveProjectAsCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar / Menu -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceVariantBrush}" Padding="0">
            <DockPanel>
                <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="{DynamicResource OnSurfaceBrush}">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}" InputGestureText="Ctrl+N" />
                        <MenuItem Header="_Open Project" Command="{Binding OpenProjectCommand}" InputGestureText="Ctrl+O" />
                        <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S" />
                        <MenuItem Header="Save Project _As..." Command="{Binding SaveProjectAsCommand}" InputGestureText="Ctrl+Shift+S" />
                        <Separator />
                        <MenuItem Header="_Recent Projects"
                                  ItemsSource="{Binding RecentProjects}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding DisplayName}" />
                                    <Setter Property="ToolTip" Value="{Binding FilePath}" />
                                    <Setter Property="Command" Value="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Setter Property="CommandParameter" Value="{Binding FilePath}" />
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="E_xit" Click="OnExitClick" InputGestureText="Alt+F4" />
                    </MenuItem>
                    <MenuItem Header="_Presets">
                        <MenuItem Header="Sports Car" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Sports Car" />
                        <MenuItem Header="Muscle Car" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Muscle Car" />
                        <MenuItem Header="SUV / Truck" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="SUV / Truck" />
                        <MenuItem Header="Motorcycle" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Motorcycle" />
                        <MenuItem Header="Boat" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Boat" />
                        <MenuItem Header="Helicopter" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Helicopter" />
                    </MenuItem>
                </Menu>
                <TextBlock Text="{Binding TitleSuffix, StringFormat='Julscha Vehicle Tool{0}'}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}" />
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Vehicle List Header + Buttons -->
                <DockPanel Grid.Row="0" Margin="12,10,12,0">
                    <TextBlock Text="VEHICLES"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+" ToolTip="Add Vehicle"
                                Command="{Binding AddVehicleCommand}"
                                Width="24" Height="24" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SecondaryBrush}"
                                FontSize="16" FontWeight="Bold" Cursor="Hand" />
                        <Button Content="-" ToolTip="Remove Vehicle"
                                Command="{Binding RemoveVehicleCommand}"
                                Width="24" Height="24" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource ErrorBrush}"
                                FontSize="16" FontWeight="Bold" Cursor="Hand"
                                Margin="4,0,0,0" />
                    </StackPanel>
                </DockPanel>

                <!-- Import Files Button -->
                <Button Grid.Row="1" Content="Import Files..."
                        Command="{Binding ImportVehicleFilesCommand}"
                        ToolTip="Import YFT/YTD/Meta files for selected vehicle"
                        Margin="12,6,12,6"
                        Padding="6,4" FontSize="11"
                        Background="{DynamicResource SurfaceBrush}"
                        Foreground="{DynamicResource OnSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Cursor="Hand" />

                <!-- Vehicle List -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Vehicles}"
                         SelectedItem="{Binding SelectedVehicle}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,0,0,4">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                Padding="12,6"
                                                BorderThickness="3,0,0,0"
                                                BorderBrush="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource SecondaryBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Separator -->
                <Border Grid.Row="3" Height="1"
                        Background="{DynamicResource BorderBrush}"
                        Margin="12,0" />

                <!-- Editors Header -->
                <TextBlock Grid.Row="4" Text="EDITORS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="12,10,12,4" />

                <!-- Editor Navigation -->
                <ListBox Grid.Row="5"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavItem}"
                         Style="{DynamicResource NavRailListBox}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       FontSize="13"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Content Area -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentViewModel}" />
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Style="{DynamicResource StatusBarStyle}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding VehicleName, StringFormat='Vehicle: {0}'}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Modified" Foreground="{DynamicResource ErrorBrush}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
