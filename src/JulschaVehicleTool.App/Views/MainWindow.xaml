<Window x:Class="JulschaVehicleTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:JulschaVehicleTool.App.ViewModels"
        xmlns:views="clr-namespace:JulschaVehicleTool.App.Views"
        Title="{Binding TitleSuffix, StringFormat='Julscha Vehicle Tool{0}'}"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <!-- DataTemplates for View switching -->
        <DataTemplate DataType="{x:Type vm:ModelViewerViewModel}">
            <views:ModelViewerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HandlingEditorViewModel}">
            <views:HandlingEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CarVariationsViewModel}">
            <views:CarVariationsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SirenEditorViewModel}">
            <views:SirenEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VehicleMetaViewModel}">
            <views:VehicleMetaView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WelcomeViewModel}">
            <views:WelcomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResourceSettingsViewModel}">
            <views:ResourceSettingsView />
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <vm:InvertBoolConverter x:Key="InvertBoolConverter" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}" />
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenProjectCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveProjectAsCommand}" />
        <KeyBinding Key="Delete" Command="{Binding RemoveVehicleCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceVariantBrush}" Padding="0">
            <DockPanel>
                <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="{DynamicResource OnSurfaceBrush}">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}" InputGestureText="Ctrl+N" />
                        <MenuItem Header="_Open Project" Command="{Binding OpenProjectCommand}" InputGestureText="Ctrl+O" />
                        <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S" />
                        <MenuItem Header="Save Project _As..." Command="{Binding SaveProjectAsCommand}" InputGestureText="Ctrl+Shift+S" />
                        <Separator />
                        <MenuItem Header="Close _Project" Command="{Binding CloseProjectCommand}" />
                        <Separator />
                        <MenuItem Header="Export Project _ZIP..." Command="{Binding ExportProjectZipCommand}" />
                        <MenuItem Header="_Import Project ZIP..." Command="{Binding ImportProjectZipCommand}" />
                        <Separator />
                        <MenuItem Header="E_xit" Click="OnExitClick" InputGestureText="Alt+F4" />
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="Add _Resource" Command="{Binding AddResourceCommand}" />
                        <MenuItem Header="Add _Vehicle" Command="{Binding AddVehicleCommand}" />
                        <Separator />
                        <MenuItem Header="Import Vehicle _Files..." Command="{Binding ImportVehicleFilesCommand}" />
                        <MenuItem Header="Import Vehicle F_older..." Command="{Binding ImportVehicleFolderCommand}" />
                        <MenuItem Header="Import _Meta File..." Command="{Binding ImportMetaFileCommand}" />
                    </MenuItem>
                    <MenuItem Header="_Presets">
                        <MenuItem Header="Sports Car" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Sports Car" />
                        <MenuItem Header="Muscle Car" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Muscle Car" />
                        <MenuItem Header="SUV / Truck" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="SUV / Truck" />
                        <MenuItem Header="Motorcycle" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Motorcycle" />
                        <MenuItem Header="Boat" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Boat" />
                        <MenuItem Header="Helicopter" Command="{Binding ApplyHandlingPresetCommand}" CommandParameter="Helicopter" />
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="_About" Click="OnAboutClick" />
                    </MenuItem>
                </Menu>
                <TextBlock Text="{Binding TitleSuffix, StringFormat='Julscha Vehicle Tool{0}'}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}" />
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: TreeView + Controls -->
            <Grid Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}"
                  Visibility="{Binding IsProjectOpen, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- TreeView Header -->
                <DockPanel Grid.Row="0" Margin="12,10,12,6">
                    <TextBlock Text="PROJECT"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+" ToolTip="Add Resource"
                                Command="{Binding AddResourceCommand}"
                                Width="24" Height="24" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SecondaryBrush}"
                                FontSize="16" FontWeight="Bold" Cursor="Hand" />
                    </StackPanel>
                </DockPanel>

                <!-- TreeView -->
                <TreeView Grid.Row="1"
                          ItemsSource="{Binding TreeNodes}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="4,0"
                          ItemContainerStyle="{StaticResource TreeViewItemStyle}"
                          SelectedItemChanged="OnTreeViewSelectedItemChanged">
                    <TreeView.Resources>
                        <!-- Project Node -->
                        <HierarchicalDataTemplate DataType="{x:Type vm:ProjectTreeNode}"
                                                  ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OnSurfaceBrush}" />
                        </HierarchicalDataTemplate>

                        <!-- Resource Node -->
                        <HierarchicalDataTemplate DataType="{x:Type vm:ResourceTreeNode}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4E6; " FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceBrush}" />
                            </StackPanel>
                            <HierarchicalDataTemplate.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource TreeViewItemStyle}">
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="Add Vehicle"
                                                          Command="{Binding DataContext.AddVehicleCommand, Source={x:Reference MainGrid}}" />
                                                <MenuItem Header="Import Vehicle Folder..."
                                                          Command="{Binding DataContext.ImportVehicleFolderCommand, Source={x:Reference MainGrid}}" />
                                                <Separator />
                                                <MenuItem Header="Delete Vehicle"
                                                          Command="{Binding DataContext.RemoveVehicleCommand, Source={x:Reference MainGrid}}" />
                                                <Separator />
                                                <MenuItem Header="Export handling.meta"
                                                          Command="{Binding DataContext.ExportSingleMetaCommand, Source={x:Reference MainGrid}}"
                                                          CommandParameter="handling" />
                                                <MenuItem Header="Export vehicles.meta"
                                                          Command="{Binding DataContext.ExportSingleMetaCommand, Source={x:Reference MainGrid}}"
                                                          CommandParameter="vehicles" />
                                                <MenuItem Header="Export carvariations.meta"
                                                          Command="{Binding DataContext.ExportSingleMetaCommand, Source={x:Reference MainGrid}}"
                                                          CommandParameter="carvariations" />
                                                <MenuItem Header="Export carcols.meta"
                                                          Command="{Binding DataContext.ExportSingleMetaCommand, Source={x:Reference MainGrid}}"
                                                          CommandParameter="carcols" />
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </HierarchicalDataTemplate.ItemContainerStyle>
                        </HierarchicalDataTemplate>

                        <!-- Vehicle Node -->
                        <DataTemplate DataType="{x:Type vm:VehicleTreeNode}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x26A0; " FontSize="12"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Visibility="{Binding HasWarning, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding DisplayName}"
                                           FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.Resources>
                </TreeView>

                <!-- Sidebar Footer -->
                <StackPanel Grid.Row="2" Margin="12,6,12,8">
                    <Button Content="+ Add Vehicle"
                            Command="{Binding AddVehicleCommand}"
                            Padding="8,4" FontSize="11"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4" />
                    <Button Content="Import Files..."
                            Command="{Binding ImportVehicleFilesCommand}"
                            Padding="8,4" FontSize="11"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"
                          Visibility="{Binding IsProjectOpen, Converter={StaticResource BoolToVis}}" />

            <!-- Content Area -->
            <Grid Grid.Column="2" x:Name="MainGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Tab Bar (visible when vehicle selected) -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceVariantBrush}"
                        Visibility="{Binding IsVehicleSelected, Converter={StaticResource BoolToVis}}">
                    <ListBox ItemsSource="{Binding TabItems}"
                             SelectedItem="{Binding SelectedTab}"
                             Style="{DynamicResource NavRailListBox}"
                             Margin="0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="TabBorder"
                                                    Background="Transparent"
                                                    Padding="16,8"
                                                    BorderThickness="0,0,0,2"
                                                    BorderBrush="Transparent">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="TabBorder" Property="Background" Value="#22FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" FontSize="13" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- View Content -->
                <ContentControl Grid.Row="1"
                                Content="{Binding CurrentViewModel}" />

                <!-- Progress Overlay -->
                <Border Grid.Row="0" Grid.RowSpan="2"
                        Background="#CC000000"
                        Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                        <TextBlock Text="{Binding ProgressMessage}"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding ProgressMax}"
                                     Value="{Binding ProgressValue}"
                                     Height="8" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Style="{DynamicResource StatusBarStyle}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding AutoSaveIndicator}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="&#169; 2026 Julscha"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
