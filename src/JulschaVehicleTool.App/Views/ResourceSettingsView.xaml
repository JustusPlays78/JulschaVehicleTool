<UserControl x:Class="JulschaVehicleTool.App.Views.ResourceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JulschaVehicleTool.App.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance vm:ResourceSettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
        <StackPanel MaxWidth="600">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="PackageVariant" Width="24" Height="24"
                                         Foreground="{DynamicResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="Resource Settings"
                           Style="{StaticResource HeaderTextStyle}"
                           FontSize="20" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Resource Info -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       FontSize="13" Margin="0,0,0,24" />

            <!-- Export Section -->
            <TextBlock Text="FIVEM EXPORT"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       Margin="0,0,0,12" />

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Output Path -->
                    <TextBlock Text="Output Folder" FontSize="12"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               Margin="0,0,0,6" />
                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding BrowseOutputPathCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Padding="12,0"
                                Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderOpen" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Browse" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="12"
                                 Foreground="{DynamicResource OnSurfaceBrush}"
                                 Background="{DynamicResource SurfaceBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" />
                    </DockPanel>

                    <!-- Export Button -->
                    <Button Command="{Binding ExportCommand}"
                            IsEnabled="{Binding IsExporting, Converter={StaticResource InvertBoolConverter}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="36"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseExport" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Export FiveM Resource" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Progress -->
                    <StackPanel Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}"
                                Margin="0,16,0,0">
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding ExportTotal}"
                                     Value="{Binding ExportProgress}"
                                     Height="4"
                                     Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="{Binding ExportProgressMessage}"
                                   FontSize="11"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
