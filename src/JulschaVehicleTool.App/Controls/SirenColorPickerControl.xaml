<UserControl x:Class="JulschaVehicleTool.App.Controls.SirenColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding Label, ElementName=Root}"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   VerticalAlignment="Center" Width="120" />

        <!-- Color preview square -->
        <Border x:Name="ColorPreview" Width="24" Height="24"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="3" Margin="0,0,8,0"
                VerticalAlignment="Center" />

        <!-- Hex input -->
        <TextBox x:Name="HexInput"
                 Text="{Binding ColorHex, ElementName=Root, UpdateSourceTrigger=LostFocus}"
                 Background="{DynamicResource SurfaceBrush}"
                 Foreground="{DynamicResource OnSurfaceBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 Width="100" Height="24" VerticalContentAlignment="Center"
                 FontFamily="Consolas" FontSize="11" Margin="0,0,8,0" />

        <!-- Preset color buttons -->
        <ItemsControl x:Name="PresetList" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </StackPanel>
</UserControl>
