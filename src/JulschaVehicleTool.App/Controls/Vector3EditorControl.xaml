<UserControl x:Class="JulschaVehicleTool.App.Controls.Vector3EditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Margin="0,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Label, ElementName=Root}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   FontSize="12" />

        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0">
            <TextBlock Text="X" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="10" />
            <TextBox Text="{Binding X, ElementName=Root, Mode=TwoWay, StringFormat=F4, UpdateSourceTrigger=LostFocus}"
                     Width="70" FontSize="11" Padding="4,2" HorizontalContentAlignment="Right" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0">
            <TextBlock Text="Y" Foreground="{DynamicResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="10" />
            <TextBox Text="{Binding Y, ElementName=Root, Mode=TwoWay, StringFormat=F4, UpdateSourceTrigger=LostFocus}"
                     Width="70" FontSize="11" Padding="4,2" HorizontalContentAlignment="Right" />
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="4,0">
            <TextBlock Text="Z" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="10" />
            <TextBox Text="{Binding Z, ElementName=Root, Mode=TwoWay, StringFormat=F4, UpdateSourceTrigger=LostFocus}"
                     Width="70" FontSize="11" Padding="4,2" HorizontalContentAlignment="Right" />
        </StackPanel>
    </Grid>
</UserControl>
