<UserControl x:Class="JulschaVehicleTool.App.Controls.NumericSliderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Margin="0,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Label with min/max range in tooltip -->
        <TextBlock Grid.Column="0"
                   Text="{Binding Label, ElementName=Root}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   FontSize="12">
            <TextBlock.ToolTip>
                <ToolTip x:Name="LabelTooltip">
                    <StackPanel>
                        <TextBlock x:Name="HintLine" Text="{Binding Hint, ElementName=Root}" FontWeight="Medium" />
                        <TextBlock x:Name="RangeLine" FontSize="11">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Range: {0} – {1}">
                                    <Binding Path="Min" ElementName="Root" />
                                    <Binding Path="Max" ElementName="Root" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </ToolTip>
            </TextBlock.ToolTip>
        </TextBlock>

        <Slider Grid.Column="1"
                Minimum="{Binding Min, ElementName=Root}"
                Maximum="{Binding Max, ElementName=Root}"
                Value="{Binding Value, ElementName=Root, Mode=TwoWay}"
                SmallChange="{Binding Step, ElementName=Root}"
                LargeChange="{Binding Step, ElementName=Root}"
                VerticalAlignment="Center"
                Margin="8,0" />

        <TextBox Grid.Column="2"
                 Text="{Binding Value, ElementName=Root, Mode=TwoWay, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center"
                 HorizontalContentAlignment="Right"
                 FontSize="11"
                 Padding="4,2" />

        <!-- Unit label — hidden when empty -->
        <TextBlock Grid.Column="3"
                   Text="{Binding Unit, ElementName=Root}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   FontSize="10"
                   Margin="4,0,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Unit, ElementName=Root}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
